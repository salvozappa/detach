# Detach Environment
# All configuration is done via environment variables.
# Copy this file to .env and customize the values for your environment.
# Docker Compose automatically reads .env files from the project directory.

# ============================================================================
# Repository Configuration
# ============================================================================

# Git repository URL to clone into sandbox on first start
# Leave empty for local development (starts with empty project directory)
# Example: git@github.com:username/repo.git
REPO_URL=

# Git user configuration for commits (optional)
# If not set, git will use its defaults or prompt
# GIT_NAME=Your Name
# GIT_EMAIL=you@example.com

# ============================================================================
# Claude Code Configuration
# ============================================================================

# Arguments passed to Claude Code CLI
# Space-separated list of flags
CLAUDE_ARGS=--dangerously-skip-permissions

# ============================================================================
# Authentication
# ============================================================================

# Authentication token (leave empty to auto-generate on startup)
# If not set, a secure token will be generated and saved to data/token
DETACH_TOKEN=

# Skip authentication entirely (INSECURE - local development only!)
# Set to: 1, true, or yes (case-insensitive) to disable authentication
# Any other value (including 0, false, no) keeps authentication enabled
# WARNING: Never use this in production or internet-exposed instances
# SKIP_AUTHENTICATION=1

# ============================================================================
# Web Push Notifications (Optional)
# ============================================================================

# VAPID keys for web push notifications
# Generate with: npx web-push generate-vapid-keys
# Leave empty to disable push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ============================================================================
# Webview Configuration
# ============================================================================

# Host for the webview (used in pairing URLs and QR codes)
# Examples:
#   - Local: localhost:8080
#   - VPS: your-vps-ip:8080
#   - Custom domain: detach.yourdomain.com
WEBVIEW_HOST=localhost:8080

# ============================================================================
# Bridge Configuration
# ============================================================================

# Sandbox SSH connection details
# Default: sandbox (Docker network hostname)
SANDBOX_HOST=sandbox
SANDBOX_PORT=22

# Path to SSH private key for bridge → sandbox connection
# Default: ../keys/bridge (relative to bridge container)
SSH_KEY_PATH=../keys/bridge

# Path to authentication token file
DETACH_TOKEN_FILE=/app/data/token

# Path to web push subscriptions storage
WEB_PUSH_SUBSCRIPTIONS_FILE=/app/data/web-push-subscriptions.json
